# ============================================================
# CONFIGURACIÓN DE SEO MCP SKILL
# ============================================================
# Copia este archivo a inputs/.env y completa con tus datos
# NUNCA subas inputs/.env al repositorio
#
# Las variables marcadas como (obligatorio) deben rellenarse sí o sí.
# Las marcadas como (opcional) pueden dejarse en blanco si no se usan.
#
# ============================================================

# --- PROVEEDOR DE IA ---
# OpenRouter (recomendado): ofrece múltiples modelos con Function Calling.
# Consigue tu API key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=tu_openrouter_api_key_aqui

# Gemini API (alternativa): modelo gratuito de Google.
# Consigue tu API key en: https://ai.google.dev/
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Modelo por defecto para OpenRouter (opcional)
# OPENROUTER_MODEL=deepseek/deepseek-chat

# --- GOOGLE ANALYTICS 4 ---
# Ruta al archivo JSON de cuenta de servicio de Google Cloud.
# Para crear la cuenta de servicio:
# 1. Ve a Google Cloud Console > IAM > Cuentas de servicio
# 2. Crea una cuenta de servicio y descarga la clave JSON
# 3. Otorga acceso a la propiedad GA4 desde Admin > Gestión de usuarios
GA4_CREDENTIALS_PATH=/ruta/completa/a/tu/ga4-service-account.json

# ID de propiedad GA4 (lo encuentras en Admin > Configuración de propiedad)
# Parece: 123456789 (numérico)
GA4_PROPERTY_ID=123456789

# --- GOOGLE SEARCH CONSOLE ---
# Ruta al archivo JSON de cuenta de servicio para GSC.
# Puede ser el mismo service account que el de GA4 si tiene acceso a GSC.
GSC_CREDENTIALS_PATH=/ruta/completa/a/tu/gsc-service-account.json

# URL del sitio verificada en Google Search Console
# Formato exacto: https://tuweb.com/ (con barra final)
GSC_SITE_URL=https://tuweb.com/

# --- PROYECTO LOCAL ---
# Ruta al directorio raíz de tu proyecto web (obligatorio para auto-corrección)
PROJECT_PATH=/ruta/a/tu/proyecto

# URL del repositorio Git remoto (para push automático)
# Ejemplo: https://github.com/tuusuario/tu-repo.git
REPO_REMOTE=https://github.com/tuusuario/tu-repo.git

# Rama de Git para hacer push (opcional, por defecto: main)
GIT_BRANCH=main

# Nombre para el remoto Git (opcional, por defecto: origin)
# GIT_REMOTE_NAME=origin

# Ruta al frontend dentro del proyecto (opcional, usado por sitemap_updater)
# Ejemplo: app/frontend
FRONTEND_PATH=app/frontend

# --- NOTIFICACIONES TELEGRAM (opcional) ---
# Token del bot de Telegram. Para crear un bot:
# 1. Habla con @BotFather en Telegram
# 2. Usa /newbot y sigue las instrucciones
# 3. Copia el token aquí
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token

# ID del chat o grupo donde se enviarán las notificaciones
# Para obtener tu chat ID, escribe a @userinfobot en Telegram
TELEGRAM_CHAT_ID=tu_chat_id

# --- BACKEND API (opcional, para enviar datos a tu panel de administración) ---
# URL base del backend donde se enviarán reportes y métricas
BACKEND_API_URL=http://localhost:3001/api

# --- CONFIGURACIÓN MCP (opcional) ---
# Servidores MCP a iniciar cuando se use el agente universal.
# Formato JSON: lista de objetos con name, command y args.
# Ejemplo con Puppeteer (navegador headless):
# MCP_SERVERS=[{"name":"browser","command":"npx","args":["-y","@modelcontextprotocol/server-puppeteer"]}]
# MCP_SERVERS=[]

# --- CONFIGURACIÓN DE IDIOMA (opcional) ---
# Idioma por defecto para generación de contenido
# DEFAULT_LANG=es

# Zona horaria para logs y programación (opcional)
# TZ=Europe/Madrid
